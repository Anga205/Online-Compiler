<section class="h-full min-w-60 border-l border-(--border-ui) bg-(--surface-0)" data-pane="right">
  <div class="flex h-12 items-center justify-between border-b border-(--border-ui) bg-(--surface-1) px-3">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-(--text-muted)">stdout</h2>
    <button
      type="button"
      class="rounded-md border border-(--accent-run) bg-(--accent-run) px-4 py-1.5 text-sm font-bold uppercase tracking-wide text-white transition-transform duration-150 hover:scale-105"
    >
      run
    </button>
  </div>

  <pre class="h-[calc(100%-3rem)] overflow-auto p-3 text-sm leading-6 text-(--text-primary)">Program output will appear here.</pre>
</section>
